# === JobMatch Environment Variables ===

# Flask
SECRET_KEY=change-this-to-random-string
PORT=5000

# MongoDB
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/jobmatch

# JWT
JWT_SECRET=change-this-to-another-random-string

# AI APIs
GEMINI_API_KEY=your-gemini-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# Facebook Groups (comma separated URLs)
FB_GROUPS=https://facebook.com/groups/jobs-israel,https://facebook.com/groups/hi-tech-jobs

# Scanner
SCAN_INTERVAL_HOURS=4

# Admin
ADMIN_EMAIL=your@email.com

# Facebook Login (for scanner)
FB_EMAIL=your-fb-email@example.com
FB_PASSWORD=your-fb-password

# SMTP (for sending CVs)
SMTP_EMAIL=your-gmail@gmail.com
SMTP_PASSWORD=your-app-password

# Upload
UPLOAD_FOLDER=uploads
